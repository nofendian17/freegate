FROM alpine:3.20
RUN apk add --no-cache tor curl bash
COPY torrc /etc/tor/torrc
COPY entrypoint-tor.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
EXPOSE 9050 9051
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -sfL --socks5 127.0.0.1:9050 https://check.torproject.org/ || exit 1
ENTRYPOINT ["/entrypoint.sh"]
