# freegate configuration

# Server port
PORT=1234

# Tor proxy settings
TOR_HOST=tor
TOR_PORT=9050
TOR_CTRL_PORT=9051
TOR_PASS=freegate

# Log level: debug, info, warn, error
LOG_LEVEL=info

# API key for client authentication (leave empty to disable auth)
API_KEY=

# Rate limit per IP (requests per minute)
RATE_LIMIT=60

# === Upstream: OpenCode (default) ===
UPSTREAM_URL_OPENCODE=https://opencode.ai/zen/v1
UPSTREAM_KEY_OPENCODE=public

# === Upstream: Kilo ===
UPSTREAM_URL_KILO=https://api.kilo.ai/api/openrouter
UPSTREAM_KEY_KILO=anonymous

# === Routing ===
# Default upstream: "opencode" or "kilo"
UPSTREAM_DEFAULT=opencode

# Comma-separated prefixes for Kilo routing
UPSTREAM_KILO_PREFIXES=kilo/,kilo-,openrouter/